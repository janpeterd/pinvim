{
  "name": "pinvim",
  "version": "0.1.0",
  "description": "Bridge between pi coding agent and Neovim — spawn Neovim from pi in tmux, annotate code without touching files, send back to pi",
  "keywords": [
    "pi-package",
    "pi-extension",
    "neovim",
    "nvim",
    "annotation"
  ],
  "files": [
    "extension.ts",
    "lua/",
    "package.json",
    "README.md"
  ],
  "type": "module",
  "pi": {
    "extensions": [
      "./extension.ts"
    ]
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/janpeterd/pinvim.git"
  },
  "author": "Jan Peter Drees <janpeterd@hey.com>",
  "license": "MIT",
  "homepage": "https://github.com/janpeterd/pinvim",
  "scripts": {
    "fmt": "oxfmt extension.ts",
    "lint": "oxlint index.ts",
    "check": "tsc --noEmit"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "^0.61.0"
  },
  "peerDependenciesMeta": {
    "@mariozechner/pi-coding-agent": {
      "optional": true
    }
  },
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "^0.61.0",
    "@types/node": "^24",
    "oxfmt": "^0.33.0",
    "oxlint": "^1.48.0",
    "typescript": "^5"
  }
}
